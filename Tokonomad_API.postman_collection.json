{
	"info": {
		"_postman_id": "tokonomad-api-collection",
		"name": "Tokonomad API",
		"description": "Complete API collection for Tokonomad game top-up platform",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/health",
					"host": ["{{base_url}}"],
					"path": ["api", "health"]
				},
				"description": "Check if the API is running"
			}
		},
		{
			"name": "Create Transaction",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userId\": \"123456789\",\n  \"zoneId\": \"8888\",\n  \"gameId\": \"ml\",\n  \"gameName\": \"Mobile Legends\",\n  \"productId\": \"ml-regular-1\",\n  \"productName\": \"86 Diamonds\",\n  \"productDescription\": \"86 Diamonds Mobile Legends\",\n  \"amount\": 20000,\n  \"paymentMethod\": \"qris\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/transactions",
					"host": ["{{base_url}}"],
					"path": ["api", "transactions"]
				},
				"description": "Create a new transaction and get Xendit payment URL"
			}
		},
		{
			"name": "Get Transaction by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/transactions/:transactionId",
					"host": ["{{base_url}}"],
					"path": ["api", "transactions", ":transactionId"],
					"variable": [
						{
							"key": "transactionId",
							"value": "TRX1234567890",
							"description": "Transaction ID"
						}
					]
				},
				"description": "Get details of a specific transaction"
			}
		},
		{
			"name": "Get All Transactions",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/transactions?page=1&limit=10",
					"host": ["{{base_url}}"],
					"path": ["api", "transactions"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "limit",
							"value": "10",
							"description": "Items per page"
						},
						{
							"key": "userId",
							"value": "",
							"description": "Filter by user ID",
							"disabled": true
						},
						{
							"key": "status",
							"value": "",
							"description": "Filter by status (PENDING, PAID, EXPIRED, FAILED)",
							"disabled": true
						},
						{
							"key": "sortBy",
							"value": "created_at",
							"description": "Sort field",
							"disabled": true
						},
						{
							"key": "sortOrder",
							"value": "DESC",
							"description": "Sort order (ASC/DESC)",
							"disabled": true
						}
					]
				},
				"description": "Get list of transactions with pagination and filtering"
			}
		},
		{
			"name": "Get Transactions by User ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/transactions?userId=123456789&page=1&limit=10",
					"host": ["{{base_url}}"],
					"path": ["api", "transactions"],
					"query": [
						{
							"key": "userId",
							"value": "123456789",
							"description": "User's game ID"
						},
						{
							"key": "page",
							"value": "1"
						},
						{
							"key": "limit",
							"value": "10"
						}
					]
				},
				"description": "Get all transactions for a specific user"
			}
		},
		{
			"name": "Get Paid Transactions",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/transactions?status=PAID&page=1&limit=10",
					"host": ["{{base_url}}"],
					"path": ["api", "transactions"],
					"query": [
						{
							"key": "status",
							"value": "PAID",
							"description": "Filter by PAID status"
						},
						{
							"key": "page",
							"value": "1"
						},
						{
							"key": "limit",
							"value": "10"
						}
					]
				},
				"description": "Get all paid transactions"
			}
		},
		{
			"name": "Xendit Webhook Test",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/webhooks/test",
					"host": ["{{base_url}}"],
					"path": ["api", "webhooks", "test"]
				},
				"description": "Test webhook endpoint"
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3001",
			"type": "string"
		}
	]
}
